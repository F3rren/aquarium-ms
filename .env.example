# Copy this file to .env and adjust values for your local environment.
# The .env file is gitignored — never commit it.
#
# All variables have safe defaults for local Docker development.
# You only need to create a .env if you want to override them.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=root

# ─── Observability ────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
