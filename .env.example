# Copy this file to .env and adjust values for your local environment.
# The .env file is gitignored — never commit it.
#
# All variables have safe defaults for local Docker development.
# You only need to create a .env if you want to override the defaults.

# ─── Docker Compose — database ────────────────────────────────────────────────
# Used by: postgres container + all Spring services (via SPRING_DATASOURCE_*)
DB_USER=postgres
DB_PASSWORD=root

# ─── Docker Compose — observability ──────────────────────────────────────────
# Used by: Grafana container
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# ─── Spring Boot standalone (without docker-compose) ─────────────────────────
# Used when running services directly with `mvn spring-boot:run` or the jar.
# If using docker-compose these are set automatically.
#
# DB_URL=jdbc:postgresql://localhost:5432/aquarium_ms
# DB_USERNAME=postgres
# DB_PASSWORD=root

# ─── CI/CD — GitHub Actions Secrets (not in .env) ────────────────────────────
# Configure these in: GitHub → Settings → Secrets and variables → Actions
#
# AWS credentials (IAM user with ECR push + ECS deploy permissions):
#   AWS_ACCESS_KEY_ID
#   AWS_SECRET_ACCESS_KEY
#   AWS_REGION                         e.g. eu-west-1
#
# Per-service ECR / ECS identifiers (one set per microservice):
#   <SERVICE>_ECR_REPOSITORY           ECR repository name
#   <SERVICE>_ECS_CLUSTER              ECS cluster name
#   <SERVICE>_ECS_SERVICE              ECS service name
#   <SERVICE>_ECS_CONTAINER            Container name in the task definition
#
# Where <SERVICE> is one of:
#   GATEWAY · AQUARIUMS · INHABITANTS · SPECIES · MAINTENANCE
#   PARAMETERS · MANUAL_PARAMETERS · TARGET_PARAMETER
